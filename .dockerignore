# Don't include non-site files in Docker image

# Source dirs not needed at runtime
design/
communication/
content/
market-research/
seo/
seo-strategy/
legal/*.md
assets/
tests/
node_modules/
coverage/

# Dev config / docs
*.md
*.docx
package.json
package-lock.json
vitest.config.js

# VCS + CI metadata
.git/
.gitignore
.github/

# Secrets — never ship (DEVOPS-M2)
.env
.env.*
*.key
*.pem
id_rsa*
*.p12
*.pfx

# Logs / temp / editor noise
*.log
*.bak
*.backup
*.old
*.swp
*.orig
*~

# Local tooling / agent state
.claude/
.antigravity/
tasks/
.DS_Store
