        }

        td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) {
            background-color: var(--light);
        }

        /* Code */
        code {
            background-color: var(--light);
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
        }

        /* Links */
        a {
            color: var(--primary);
            text-decoration: none;
        }

        a:hover {
            color: var(--secondary);
            text-decoration: underline;
        }

        /* Footer */
        footer {
            background-color: var(--secondary);
            color: white;
            padding: 3rem 2rem;
            margin-top: 3rem;
            text-align: center;
        }

        footer h3 {
            color: var(--primary);
            margin-top: 0;
